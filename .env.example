# Supabase (pegue em supabase.com -> seu projeto -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxx

# Resend (resend.com -> API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Matriz do Destino <entrega@seudominio.com>

# Segredo para validar que o webhook realmente veio da Kiwify
# (defina qualquer string forte aqui e cole o mesmo valor na configuração
# de webhook da Kiwify, se ela permitir um "token" ou "secret" na URL)
KIWIFY_WEBHOOK_SECRET=escolha-uma-string-longa-e-aleatoria

# Segredo para proteger a rota de cron (Vercel Cron envia esse header sozinho
# se você configurar em vercel.json, mas mantemos um segredo extra por segurança)
CRON_SECRET=outra-string-longa-e-aleatoria
